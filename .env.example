# Neon Database (get from Neon Console)
DATABASE_URL="postgresql://..."

# Auth JWT Secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-key-here"

# Admin credentials
ADMIN_EMAIL="admin@rifas.app"
ADMIN_PASSWORD="your-password"

# Mercado Pago defaults (can be edited from /admin/configuracion)
MP_ALIAS="tu.alias.mp"
MP_CBU="0000003100000000000001"
MP_TITULAR="Nombre del Titular"
ADMIN_WHATSAPP="5491123456789"
