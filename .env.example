# Neon Database (get from Neon Console)
DATABASE_URL="postgresql://..."

# Auth JWT Secret (generate with: openssl rand -base64 32)
AUTH_SECRET="your-secret-key-here"

# Admin credentials
ADMIN_EMAIL="admin@rifas.app"
ADMIN_PASSWORD="your-password"

# Mercado Pago API (real payments)
# Prefijo APP_USR = producción | TEST = sandbox
MP_ACCESS_TOKEN="APP_USR-0000-xxxx"

# Public key for frontend (if needed)
MP_PUBLIC_KEY="APP_USR-xxxx"

# Mercado Pago defaults (can be edited from /admin/configuracion)
MP_ALIAS="tu.alias.mp"
MP_CBU="0000003100000000000001"
MP_TITULAR="Nombre del Titular"
ADMIN_WHATSAPP="5491123456789"

# Public URL (needed for MP webhook and redirects)
# En producción: https://tudominio.com
# En local: usar ngrok -> https://xxxx.ngrok.io
SITE_URL="http://localhost:3000"
